{
  "name": "memory",
  "version": "0.12.1",
  "description": "Persistent memory for Claude Code (SQLite + FTS5) — capture via hooks, search via MCP.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsup && node scripts/postbuild.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "tsx src/server.ts",
    "migrate": "node --no-warnings dist/migrate.js",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test test/*.test.mts",
    "test": "npm run build && node --test test/*.test.mjs && tsx --test test/*.test.mts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "memory": "file:",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
