{
  "description": "memory ingestion hooks — capture brute des mémoires de session vers SQLite local",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"${CLAUDE_PLUGIN_ROOT}/dist/hook.js\" sessionstart",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"${CLAUDE_PLUGIN_ROOT}/dist/hook.js\" prompt",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"${CLAUDE_PLUGIN_ROOT}/dist/hook.js\" observe",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"${CLAUDE_PLUGIN_ROOT}/dist/hook.js\" stop",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --no-warnings \"${CLAUDE_PLUGIN_ROOT}/dist/hook.js\" sessionend",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
